# Copie para .env e preencha. NUNCA commitar .env.
# Veja TASKS.md (Fase 0) e IDEA.md §7.7 (Segredos).

# Supabase (cliente Flutter — apenas anon key, NUNCA service_role)
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Sentry
SENTRY_DSN=
SENTRY_ENV=dev

# PostHog
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com

# Base URL pública pra montar links de convite (§7.3).
# Web em produção: https://kadett-preto.github.io/ninho
# Mobile (universal link futuro): https://ninho.app
# Vazio = no web deriva de Uri.base; no mobile cai em ninho.app.
INVITE_BASE_URL=

# Claude API — NUNCA embarcar no cliente.
# Configurar apenas em Edge Functions (Supabase Vault / secrets).
# ANTHROPIC_API_KEY=
