{
  "fmt": {
    "include": ["**/*.ts"],
    "exclude": ["**/*.generated.ts"],
    "lineWidth": 80,
    "indentWidth": 2,
    "semiColons": true,
    "singleQuote": false
  },
  "lint": {
    "include": ["**/*.ts"],
    "rules": {
      "tags": ["recommended"],
      "exclude": [
        "no-explicit-any"
      ]
    }
  }
}
